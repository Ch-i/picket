{
  "name": "picket",
  "version": "0.1.0",
  "private": true,
  "description": "LLM-native IDS/IPS console for pfSense (Suricata + Snort) — Ember + Lit + MCP",
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "selftest": "node packages/pfsense-client/dist/selftest.js",
    "mcp": "node packages/mcp-server/dist/index.js",
    "serve": "node packages/backend/dist/server.js",
    "web": "pnpm --filter picket-web start"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "ember-cli": "^7.0.1"
  }
}
