# Picket backend — copy to `.env` (gitignored). Auth lives ONLY here. Pick ONE:
#
# (a) API key:
# ANTHROPIC_API_KEY=sk-ant-...
#
# (b) Claude Code subscription login (no key): run `claude` to log in once, then point Picket
#     at its credential. Defaults to ~/.claude/.credentials.json of the service user; set this
#     if the login belongs to a different user:
# PICKET_CLAUDE_CREDS=/home/you/.claude/.credentials.json
#
# Leave both unset for the safe, auth-free demo.

# Model + reasoning (optional)
PICKET_MODEL=claude-opus-4-8
PICKET_EFFORT=medium
PICKET_PORT=8200

# Data source: demo fixtures (default) or a live pfSense box
PICKET_BACKEND=demo

# (a) REST API package — read + write (rule toggles / suppressions)
# PICKET_BACKEND=pfsense
# PICKET_PFSENSE_URL=https://pfsense.lan
# PICKET_PFSENSE_KEY=...            # pfSense REST API token

# (b) SSH — live Suricata EVE alert feed, read-only (no REST package needed)
# PICKET_BACKEND=pfsense-ssh
# PICKET_PFSENSE_SSH=admin@192.168.1.1
# PICKET_PFSENSE_SSH_KEY=/home/you/.ssh/id_pfsense   # optional; else agent/password
# PICKET_EVE_GLOB=/var/log/suricata/*/eve.json       # override if your path differs

# Opt in to applying rule toggles / suppressions (off by default)
# PICKET_ALLOW_WRITES=1
